{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "../../dist",
    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts"],
  "exclude": [
    "test/**/*.ts",
    "**/*.spec.ts",
    "../shared/**/*.spec.ts",
    "../../node_modules",
    "../../dist"
  ]
}
