{
  "name": "structure-multi-tenant",
  "version": "0.1.0",
  "private": true,
  "description": "Base multi-tenant platform with NestJS API and worker",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
